/*
 * nRF52840 Dongle devicetree overlay for AD5940 impedance analyzer
 * 
 * Pin assignments:
 * P0.13 - SPI SCK
 * P0.17 - SPI MOSI  
 * P0.20 - SPI MISO
 * P0.15 - SPI CS (Manual control in code)
 * P0.22 - AD5940 RESET (Manual control in code)
 * P0.31 - AD5940 INT (Manual control in code)
 */

&pinctrl {
    spi1_default: spi1_default {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 13)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 17)>,
                    <NRF_PSEL(SPIM_MISO, 0, 20)>;
        };
    };

    spi1_sleep: spi1_sleep {
        group1 {
            psels = <NRF_PSEL(SPIM_SCK, 0, 13)>,
                    <NRF_PSEL(SPIM_MOSI, 0, 17)>,
                    <NRF_PSEL(SPIM_MISO, 0, 20)>;
            low-power-enable;
        };
    };
};

&spi1 {
    compatible = "nordic,nrf-spim";
    status = "okay";
    pinctrl-0 = <&spi1_default>;
    pinctrl-1 = <&spi1_sleep>;
    pinctrl-names = "default", "sleep";
};
