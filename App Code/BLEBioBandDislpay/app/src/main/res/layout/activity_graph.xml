<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2C3E50"
    tools:context=".GraphActivity">

    <!-- Scrollable container for stats to ensure they fit -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">

        <LinearLayout
            android:id="@+id/emg_stats_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- V(rms) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="V(rms)"
                    android:textColor="#BDC3C7"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/vrms_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- mV"
                    android:textColor="@android:color/white"
                    android:textSize="48sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- TDMF -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:layout_marginBottom="32dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mean Frequency (TDMF)"
                    android:textColor="#BDC3C7"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/tdmf_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- Hz"
                    android:textColor="@android:color/white"
                    android:textSize="48sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Muscle Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Muscle Status"
                    android:textColor="#BDC3C7"
                    android:textSize="18sp" />
                <TextView
                    android:id="@+id/muscle_status_text"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Resting"
                    android:textColor="@android:color/white"
                    android:textSize="32sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <Button
        android:id="@+id/back_button_emg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_margin="16dp"
        android:text="Back to main page" />

</RelativeLayout>
